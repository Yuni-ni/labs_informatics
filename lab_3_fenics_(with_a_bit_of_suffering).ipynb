    "gmsh.model.mesh.field.setString(field, \"F\", \"1\")  \n",
    "gmsh.model.mesh.field.setAsBackgroundMesh(field)\n",
    "\n",
    "gmsh.model.mesh.generate(3)\n",
    "\n",
    "####\n",
    "# trying to add physical groups\n",
