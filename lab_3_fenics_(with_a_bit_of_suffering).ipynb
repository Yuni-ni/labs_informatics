   "outputs": [],
   "source": [
    "lmbda = 1.0e-02 * 10  # surface parameter\n",
    "dt = 1e-5  # time step\n",
    "theta = 0.5  # time stepping family, e.g. theta=1 -> backward Euler, theta=0.5 -> Crank-Nicholson\n",
    "t = 0.0  # Current time"
   ]
